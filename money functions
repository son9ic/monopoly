function movePlayer(playerIndex, spaces){

    const player = players[playerIndex];

    const oldPosition = player.position;

    player.position += spaces;

    if(player.position >= 40){

        player.position -= 40;

        addMoney(playerIndex, 200);

        alert(
            player.name +
            " passed GO and collected $200!"
        );
    }

    updateMoneyDisplay();
} 
<div id="moneyPanel"></div> 
function updateMoneyDisplay(){

    let html = "";

    players.forEach(player=>{

        html += `
        <div>
            ${player.name}
            : $${player.money}
        </div>
        `;
    });

    document.getElementById(
        "moneyPanel"
    ).innerHTML = html;
} 
function buyProperty(
    playerIndex,
    property
){

    const player = players[playerIndex];

    if(player.money >= property.price){

        player.money -= property.price;

        player.properties.push(
            property.name
        );

        property.owner = playerIndex;

        updateMoneyDisplay();

        alert(
            player.name +
            " bought " +
            property.name
        );
    }
    else{

        alert(
            "Not enough money!"
        );
    }
} 
