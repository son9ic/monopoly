function payRent(
    playerIndex,
    property
){

    if(property.owner === null){
        return;
    }

    if(property.owner === playerIndex){
        return;
    }

    const rent = property.rent;

    payMoney(
        playerIndex,
        rent
    );

    addMoney(
        property.owner,
        rent
    );
} 
